<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundStartColor">#FFF6EFE4</Color>
    <Color x:Key="AppBackgroundEndColor">#FFE5ECF4</Color>
    <Color x:Key="SurfaceColor">#FFFDFEFF</Color>
    <Color x:Key="SurfaceSoftColor">#FFF2F6FA</Color>
    <Color x:Key="ShellStartColor">#FF152430</Color>
    <Color x:Key="ShellEndColor">#FF1F3342</Color>
    <Color x:Key="AccentColor">#FF0F8F8A</Color>
    <Color x:Key="AccentAltColor">#FF36A3FF</Color>
    <Color x:Key="ForegroundColor">#FF1B2630</Color>
    <Color x:Key="SubtleTextColor">#FF5F6F7D</Color>
    <Color x:Key="BorderColor">#FFD6E0EA</Color>
    <Color x:Key="GoodColor">#FF1E9E69</Color>
    <Color x:Key="WarnColor">#FFDA8A18</Color>
    <Color x:Key="BadColor">#FFD94D4D</Color>
    <Color x:Key="NeutralPillColor">#FF8AA2B5</Color>

    <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0.0" Color="{StaticResource AppBackgroundStartColor}" />
        <GradientStop Offset="1.0" Color="{StaticResource AppBackgroundEndColor}" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ShellGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="{StaticResource ShellStartColor}" />
        <GradientStop Offset="1.0" Color="{StaticResource ShellEndColor}" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceSoftBrush" Color="{StaticResource SurfaceSoftColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentAltBrush" Color="{StaticResource AccentAltColor}" />
    <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource ForegroundColor}" />
    <SolidColorBrush x:Key="SubtleTextBrush" Color="{StaticResource SubtleTextColor}" />
    <SolidColorBrush x:Key="BorderBrushColor" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="GoodBrush" Color="{StaticResource GoodColor}" />
    <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource WarnColor}" />
    <SolidColorBrush x:Key="BadBrush" Color="{StaticResource BadColor}" />
    <SolidColorBrush x:Key="NeutralPillBrush" Color="{StaticResource NeutralPillColor}" />
</ResourceDictionary>
