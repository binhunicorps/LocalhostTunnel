<UserControl x:Class="LocalhostTunnel.Desktop.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <UniformGrid Rows="1" Columns="3">
            <Border Margin="0,0,10,0" Style="{StaticResource SoftPanelStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="Tunnel Status" />
                    <TextBlock Margin="0,4,0,0" Style="{StaticResource CardValueTextStyle}" Text="{Binding TunnelLabel}" />
                    <TextBlock Margin="0,2,0,0"
                               Style="{StaticResource ShellSubtitleTextStyle}"
                               Text="Cloudflare tunnel link health" />
                </StackPanel>
            </Border>

            <Border Margin="0,0,10,0" Style="{StaticResource SoftPanelStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="Forwarder Status" />
                    <TextBlock Margin="0,4,0,0" Style="{StaticResource CardValueTextStyle}" Text="{Binding ForwarderLabel}" />
                    <TextBlock Margin="0,2,0,0"
                               Style="{StaticResource ShellSubtitleTextStyle}"
                               Text="Inbound request processing" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SoftPanelStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="Runtime Uptime" />
                    <TextBlock Margin="0,4,0,0" Style="{StaticResource CardValueTextStyle}" Text="{Binding UptimeLabel}" />
                    <TextBlock Margin="0,2,0,0"
                               Style="{StaticResource ShellSubtitleTextStyle}"
                               Text="Elapsed from active runtime" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Style="{StaticResource SoftPanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="Live Event Feed" />
                <ListBox Grid.Row="1"
                         Margin="0,10,0,0"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemsSource="{Binding LiveLogs}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    CornerRadius="10"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrushColor}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               Text="{Binding Timestamp, Converter={StaticResource HoChiMinhTimeConverter}, ConverterParameter='HH:mm:ss'}" />
                                    <TextBlock Grid.Column="1"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold"
                                               Text="{Binding Source}" />
                                    <TextBlock Grid.Column="2"
                                               Foreground="{StaticResource ForegroundBrush}"
                                               Text="{Binding Message}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
