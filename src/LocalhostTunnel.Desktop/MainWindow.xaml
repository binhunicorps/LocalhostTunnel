<Window x:Class="LocalhostTunnel.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LocalhostTunnel.Desktop.Views"
        xmlns:vm="clr-namespace:LocalhostTunnel.Desktop.ViewModels"
        Title="Localhost Tunnel"
        Icon="/Assets/localhost-tunnel.ico"
        Width="1200"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:OverviewViewModel}">
            <views:OverviewView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfigurationViewModel}">
            <views:ConfigurationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
            <views:LogsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DiagnosticsViewModel}">
            <views:DiagnosticsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UpdatesViewModel}">
            <views:UpdatesView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Ellipse Width="420"
                 Height="420"
                 Fill="#2A36A3FF"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-160,-130,0,0"
                 IsHitTestVisible="False" />
        <Ellipse Width="360"
                 Height="360"
                 Fill="#1D0F8F8A"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-120,-100"
                 IsHitTestVisible="False" />

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SidebarShellStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="44"
                                Height="44"
                                CornerRadius="14"
                                Margin="0,0,10,0"
                                Background="{StaticResource AccentBrush}">
                            <Grid>
                                <Ellipse Width="26" Height="26" Fill="#35FFFFFF" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,3,0" />
                                <Path Stroke="White"
                                      StrokeThickness="3"
                                      StrokeLineJoin="Round"
                                      Data="M14,11 L14,31 L30,31" />
                                <Path Stroke="#D3F3FF"
                                      StrokeThickness="2.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M11,14 L23,14" />
                            </Grid>
                        </Border>
                        <StackPanel>
                            <TextBlock FontFamily="Bahnschrift SemiBold"
                                       FontSize="20"
                                       Foreground="White"
                                       Text="Localhost Tunnel" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource NavLabelTextStyle}"
                                       Foreground="#C6D9E8"
                                       Text="Desktop Command Center" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,24,0,0">
                        <Button Command="{Binding ShowOverviewCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentRoute}" Value="overview">
                                            <Setter Property="Background" Value="#3A36A3FF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavLabelTextStyle}" Text="Overview" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ShowConfigurationCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentRoute}" Value="configuration">
                                            <Setter Property="Background" Value="#3A36A3FF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavLabelTextStyle}" Text="Configuration" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ShowLogsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentRoute}" Value="logs">
                                            <Setter Property="Background" Value="#3A36A3FF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavLabelTextStyle}" Text="Logs" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ShowDiagnosticsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentRoute}" Value="diagnostics">
                                            <Setter Property="Background" Value="#3A36A3FF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavLabelTextStyle}" Text="Diagnostics" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ShowUpdatesCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentRoute}" Value="updates">
                                            <Setter Property="Background" Value="#3A36A3FF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavLabelTextStyle}" Text="Updates" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Grid.Row="2" Style="{StaticResource SoftPanelStyle}" Background="#1AFFFFFF" BorderBrush="#2FFFFFFF">
                        <TextBlock Foreground="#D8EBF8"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Tip: Use Configuration to validate token and ports before starting runtime." />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="16,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardPanelStyle}" Padding="22">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       Text="{Binding CurrentSectionTitle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource ShellSubtitleTextStyle}"
                                       Text="{Binding CurrentSectionDescription}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource ShellSubtitleTextStyle}"
                                       Foreground="{StaticResource AccentAltBrush}"
                                       Text="{Binding RuntimeStatusMessage}" />
                            <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                                <Border Margin="0,0,10,0"
                                        MinWidth="170"
                                        Style="{StaticResource SoftPanelStyle}"
                                        Padding="10,6">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource NeutralPillBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TunnelStateTone}" Value="good">
                                                            <Setter Property="Fill" Value="{StaticResource GoodBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TunnelStateTone}" Value="warn">
                                                            <Setter Property="Fill" Value="{StaticResource WarnBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TunnelStateTone}" Value="bad">
                                                            <Setter Property="Fill" Value="{StaticResource BadBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="Tunnel: " />
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{StaticResource ForegroundBrush}"
                                                   Text="{Binding TunnelState}" />
                                    </StackPanel>
                                </Border>

                                <Border MinWidth="190"
                                        Style="{StaticResource SoftPanelStyle}"
                                        Padding="10,6">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource NeutralPillBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ForwarderStateTone}" Value="good">
                                                            <Setter Property="Fill" Value="{StaticResource GoodBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ForwarderStateTone}" Value="warn">
                                                            <Setter Property="Fill" Value="{StaticResource WarnBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ForwarderStateTone}" Value="bad">
                                                            <Setter Property="Fill" Value="{StaticResource BadBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="Forwarder: " />
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{StaticResource ForegroundBrush}"
                                                   Text="{Binding ForwarderState}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Margin="0,0,8,0"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Content="Start Runtime"
                                    Command="{Binding StartCommand}" />
                            <Button Style="{StaticResource SecondaryActionButtonStyle}"
                                    Content="Stop Runtime"
                                    Command="{Binding StopCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="0,14,0,0" Opacity="0" Style="{StaticResource CardPanelStyle}" Padding="12">
                    <Border.RenderTransform>
                        <TranslateTransform Y="10" />
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0"
                                                     To="1"
                                                     Duration="0:0:0.28" />
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                     From="10"
                                                     To="0"
                                                     Duration="0:0:0.28" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ContentControl Content="{Binding CurrentContent}" />
                        <TextBlock Grid.Row="1"
                                   HorizontalAlignment="Right"
                                   Margin="0,10,4,2"
                                   Style="{StaticResource ShellSubtitleTextStyle}">
                            <Run Text="Last refresh: " />
                            <Run Text="{Binding LastUpdatedAt, Converter={StaticResource HoChiMinhTimeConverter}, ConverterParameter='HH:mm:ss'}" />
                            <Run Text="  " />
                            <Run Text="{Binding TimeZoneLabel, Mode=OneWay}" />
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
